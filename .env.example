# Site URL (used for metadata, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://saiki.id

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 (if using directly instead of GTM)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXX

# Supabase (for inquiry storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin Portal
ADMIN_PASSWORD=your-secure-admin-password

# Email Notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=saikigroup.id@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_SECURE=false
MAIL_FROM_EMAIL=saikigroup.id@gmail.com
MAIL_FROM_NAME=SAIKI Group
ADMIN_EMAIL=saikigroup.id@gmail.com
